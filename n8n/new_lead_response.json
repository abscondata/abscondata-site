        "jsCode": "// Validation failed — create task with error status and exception row.\nconst item = $input.first();\nconst parsed = item.json._parsed;\nconst errorReason = item.json._errorReason || 'VALIDATION_FAILED';\nconst errorStatus = item.json._errorStatus || 'EXCEPTION';\n\nreturn [{\n  json: {\n    task: {\n      title: 'Lead: ' + (parsed?.senderName || parsed?.senderEmail || 'unknown'),\n      workflow_type: 'NEW_LEAD_RESPONSE',\n      status: errorStatus,\n      client_id: 'FILL_IN_CLIENT_ID',\n      source_system: 'gmail',\n      source_record_id: parsed?.messageId || '',\n      recipient_email: parsed?.senderEmail || '',\n      recipient_name: parsed?.senderName || '',\n      task_type: 'lead_response',\n      exception_reason_code: errorReason,\n      exception_description: item.json._errorReason\n    },\n    exception: {\n      issue_type: 'validation_failure',\n      severity: 'medium',\n      description: errorReason,\n      resolution_status: 'open'\n    }\n  }\n}];"
