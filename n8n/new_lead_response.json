    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst taskId = $('Create Task').first().json.id;\nlet aiDraft = null;\ntry {\n  const text = item.json?.content?.[0]?.text;\n  if (text && typeof text === 'string' && text.trim().length > 0) {\n    aiDraft = text.trim();\n  }\n} catch (e) {\n  aiDraft = null;\n}\nreturn [{ json: { taskId, aiDraft } }];"
      },
