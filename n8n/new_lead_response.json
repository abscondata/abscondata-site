      "id": "check-duplicate-rpc",
      "name": "Check Duplicate (RPC)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Validate email fields and duplicate check result.\n// If any check fails, output to error branch with reason.\n\nconst item = $input.first();\nconst parsed = item.json._parsed;\nconst duplicateResult = item.json;\n\n// Check for duplicate (RPC returns true/false or count)\n// If the HTTP request returned data indicating a duplicate, reject\nconst isDuplicate = Array.isArray(duplicateResult) && duplicateResult.length > 0 && duplicateResult[0] === true;\n\nconst errors = [];\n\nif (!parsed.senderEmail) errors.push('sender_email is empty');\nif (!parsed.subject) errors.push('subject is empty');\nif (!parsed.body || parsed.body.trim().length === 0) errors.push('body is empty');\n\n// Alternative duplicate check: query task_source_data directly\n// This node will be preceded by an actual Supabase query in production.\n// For now, the RPC call handles it. If it errored, we skip duplicate check.\n\nif (errors.length > 0) {\n  return [\n    [],\n    [{\n      json: {\n        ...item.json,\n        _validationError: true,\n        _errorReason: errors.join('; '),\n        _errorStatus: 'WAITING_ON_MISSING_DATA'\n      }\n    }]\n  ];\n}\n\n// Pass through valid item\nreturn [\n  [{ json: item.json }],\n  []\n];"
      },
