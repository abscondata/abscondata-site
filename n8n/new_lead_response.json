        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1024, system: 'You are a professional assistant for a small service business. Your job is to draft a brief, warm, professional first-touch reply to an inbound lead email. Acknowledge their inquiry, confirm they reached the right place, and tell them someone will follow up shortly to discuss their needs. Do not include pricing, scheduling, or technical diagnosis. Do not make promises you cannot keep. Sign off with the business name only. Return only the email body text, no subject line, no metadata.', messages: [{ role: 'user', content: 'Draft a reply to this inbound lead email.\\n\\nFrom: ' + $('Extract Fields').first().json.senderName + '\\nSubject: ' + $('Extract Fields').first().json.subject + '\\nMessage:\\n' + $('Extract Fields').first().json.body }] }) }}",
        "options": {}
