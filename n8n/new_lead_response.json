      "id": "a1000000-0000-0000-0000-000000000001",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        300
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "",
          "name": "Gmail OAuth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nconst excludePatterns = [\n  'noreply', 'no-reply', 'donotreply', 'do-not-reply',\n  'notifications@', 'notification@', 'alerts@', 'alert@',\n  'newsletter@', 'news@', 'marketing@', 'promo@',\n  'updates@', 'info@mailchimp', 'bounce@',\n  'mailer-daemon', 'postmaster@',\n  'support@google', 'calendar-notification'\n];\n\n// Safely convert any value to a string. Handles objects like\n// {name: 'John', email: 'john@x.com'}, arrays, null, undefined.\nfunction toStr(val) {\n  if (val == null) return '';\n  if (typeof val === 'string') return val;\n  if (typeof val === 'object') {\n    // Gmail sometimes returns from as {name, email}\n    if (val.email) return val.name ? (val.name + ' <' + val.email + '>') : val.email;\n    if (val.value) return String(val.value);\n    if (Array.isArray(val)) return val.map(toStr).join(', ');\n  }\n  return String(val);\n}\n\nfor (const item of items) {\n  const d = item.json;\n  const headers = d.payload?.headers ?? [];\n  const getHeader = (name) => {\n    const h = headers.find(h => String(h.name || '').toLowerCase() === name);\n    return h ? toStr(h.value) : '';\n  };\n\n  const rawFrom = toStr(getHeader('from') || d.from || '').toLowerCase();\n  const subject = toStr(getHeader('subject') || d.subject || '');\n  const inReplyTo = toStr(getHeader('in-reply-to'));\n  const references = toStr(getHeader('references'));\n\n  if (!rawFrom) continue;\n  if (excludePatterns.some(p => rawFrom.includes(p))) continue;\n  if (inReplyTo || references) continue;\n\n  const body = toStr(d.text || d.textPlain || d.snippet || '');\n  if (!body.trim()) continue;\n\n  const m = rawFrom.match(/^(.+?)\\s*<(.+?)>$/);\n  const senderName = m ? m[1].replace(/\"/g, '').trim() : '';\n  const senderEmail = m ? m[2].trim() : rawFrom.trim();\n  const messageId = toStr(d.id || d.messageId || '');\n  const receivedAt = d.internalDate\n    ? new Date(parseInt(d.internalDate)).toISOString()\n    : new Date().toISOString();\n\n  results.push({\n    json: {\n      messageId,\n      senderName,\n      senderEmail,\n      subject,\n      body,\n      bodyExcerpt: body.substring(0, 500),\n      receivedAt,\n      rawEmail: d\n    }\n  });\n}\n\nreturn results;"
      },
