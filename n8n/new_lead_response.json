    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst content = item.json?.content?.[0]?.text ?? '';\ntry {\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (!match) throw new Error('No JSON in response');\n  const parsed = JSON.parse(match[0]);\n  if (!parsed.draft_body || parsed.draft_body.trim().length < 20) throw new Error('Draft too short');\n  return [{ json: { success: true, subjectLine: parsed.subject_line || ('Re: ' + ($('Filter Leads').first().json.subject || 'Your inquiry')), draftBody: parsed.draft_body } }];\n} catch (e) {\n  return [{ json: { success: false, errorReason: 'LOW_CONFIDENCE_DRAFT', errorDescription: e.message } }];\n}"
      },
