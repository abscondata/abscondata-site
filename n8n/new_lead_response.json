      "id": "n1",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [0, 300],
      "credentials": { "gmailOAuth2": { "id": "", "name": "Gmail account" } }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nconst exclude = ['noreply','no-reply','donotreply','do-not-reply','notifications@','notification@','alerts@','alert@','newsletter@','news@','marketing@','promo@','updates@','info@mailchimp','bounce@','mailer-daemon','postmaster@','support@google','calendar-notification'];\nfunction toStr(v){if(v==null)return '';if(typeof v==='string')return v;if(typeof v==='object'){if(v.email)return v.name?(v.name+' <'+v.email+'>'):v.email;if(v.value)return String(v.value);if(Array.isArray(v))return v.map(toStr).join(', ');}return String(v);}\nfor(const item of items){\n  const d=item.json;\n  const hdrs=d.payload?.headers??[];\n  const gh=(n)=>{const h=hdrs.find(x=>String(x.name||'').toLowerCase()===n);return h?toStr(h.value):'';};\n  const rawFrom=toStr(gh('from')||d.from||'').toLowerCase();\n  const subject=toStr(gh('subject')||d.subject||'');\n  const inReplyTo=toStr(gh('in-reply-to'));\n  const refs=toStr(gh('references'));\n  if(!rawFrom)continue;\n  if(exclude.some(p=>rawFrom.includes(p)))continue;\n  if(inReplyTo||refs)continue;\n  const body=toStr(d.text||d.textPlain||d.snippet||'');\n  if(!body.trim())continue;\n  const m=rawFrom.match(/^(.+?)\\s*<(.+?)>$/);\n  const senderName=m?m[1].replace(/\"/g,'').trim():'';\n  const senderEmail=m?m[2].trim():rawFrom.trim();\n  const messageId=toStr(d.id||d.messageId||'');\n  const receivedAt=d.internalDate?new Date(parseInt(d.internalDate)).toISOString():new Date().toISOString();\n  results.push({json:{messageId,senderName,senderEmail,subject,body,bodyExcerpt:body.substring(0,500),receivedAt,rawEmail:d}});\n}\nreturn results;"
      },
