      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "FILL_IN_ANTHROPIC_API_KEY" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a professional operations assistant drafting email replies for a managed back-office operations company.\\n\\nCOMPANY CONTEXT:\\n- Business name: Abscondata\\n- Service area: Managed back-office operations for service companies\\n- Tone: Professional, warm, concise. No jargon. No hard sell. Acknowledge their inquiry, show competence, suggest a brief call.\\n\\nINBOUND EMAIL:\\n- From: {{ $('Filter Leads').first().json._parsed.senderName }} <{{ $('Filter Leads').first().json._parsed.senderEmail }}>\\n- Subject: {{ $('Filter Leads').first().json._parsed.subject }}\\n- Body excerpt: {{ $('Filter Leads').first().json._parsed.bodyExcerpt }}\\n\\nTASK:\\nDraft a reply email. Return valid JSON only, no markdown:\\n{\\n  \\\"subject_line\\\": \\\"Re: [original subject or improved version]\\\",\\n  \\\"draft_body\\\": \\\"[full email reply body, 3-5 sentences, sign off as Abscondata Team]\\\"\\n}\"\n    }\n  ]\n}"
      },
      "id": "ai-draft",
      "name": "AI Draft Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1580, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Parse Anthropic response and extract draft.\nconst item = $input.first();\nconst response = item.json;\n\n// Extract text content from Anthropic response\nconst content = response.content?.[0]?.text ?? '';\n\nlet parsed;\ntry {\n  // Try to parse the JSON from the response\n  const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n  if (!jsonMatch) throw new Error('No JSON found in response');\n  parsed = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  // Malformed response — flag as exception\n  return [[], [{\n    json: {\n      _draftError: true,\n      _errorReason: 'LOW_CONFIDENCE_DRAFT',\n      _errorDescription: 'AI response was empty or malformed: ' + e.message,\n      _rawResponse: content.substring(0, 500)\n    }\n  }]];\n}\n\nif (!parsed.draft_body || parsed.draft_body.trim().length < 20) {\n  return [[], [{\n    json: {\n      _draftError: true,\n      _errorReason: 'LOW_CONFIDENCE_DRAFT',\n      _errorDescription: 'Draft body is empty or too short',\n      _rawResponse: content.substring(0, 500)\n    }\n  }]];\n}\n\nreturn [[\n  {\n    json: {\n      subjectLine: parsed.subject_line || 'Re: ' + ($('Filter Leads').first().json._parsed.subject || 'Your inquiry'),\n      draftBody: parsed.draft_body\n    }\n  }\n], []];"
      },
      "id": "parse-ai-response",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
