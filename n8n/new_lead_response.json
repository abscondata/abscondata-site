    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst content = item.json?.content?.[0]?.text ?? '';\n\nlet parsed;\ntry {\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (!match) throw new Error('No JSON object in response');\n  parsed = JSON.parse(match[0]);\n  if (!parsed.draft_body || parsed.draft_body.trim().length < 20) {\n    throw new Error('Draft body empty or too short');\n  }\n} catch (e) {\n  return [{\n    json: {\n      success: false,\n      errorReason: 'LOW_CONFIDENCE_DRAFT',\n      errorDescription: e.message,\n      rawResponse: content.substring(0, 500)\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    subjectLine: parsed.subject_line || ('Re: ' + ($('Filter Leads').first().json.subject || 'Your inquiry')),\n    draftBody: parsed.draft_body\n  }\n}];"
      },
