    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const d = item.json;\n  const rawFrom = String(d.from || '');\n  let senderEmail = rawFrom;\n  let senderName = rawFrom;\n  const emailMatch = rawFrom.match(/<([^>]+)>/);\n  if (emailMatch) {\n    senderEmail = emailMatch[1].trim();\n    const namePart = rawFrom.replace(/<[^>]+>/, '').trim().replace(/^\"|\"$/g, '');\n    senderName = namePart || senderEmail;\n  } else {\n    const bareEmail = rawFrom.match(/[\\w.+-]+@[\\w.-]+/);\n    if (bareEmail) senderEmail = bareEmail[0];\n    senderName = senderEmail;\n  }\n  const subject = String(d.subject || '');\n  const body = String(d.text || d.snippet || '');\n  const receivedAt = String(d.date || new Date().toISOString());\n  const gmailMessageId = String(d.id || '');\n  const gmailThreadId = String(d.threadId || '');\n  results.push({ json: { senderEmail, senderName, subject, body, receivedAt, gmailMessageId, gmailThreadId } });\n}\nreturn results;"
      },
      "id": "node-02",
      "name": "Extract Fields",
      "type": "n8n-nodes-base.code",
