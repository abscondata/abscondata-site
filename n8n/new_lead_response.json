      "id": "n3",
      "name": "Check Duplicate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "credentials": { "httpHeaderAuth": { "id": "", "name": "Header Auth account 2" } }
    },
    {
      "parameters": {
        "jsCode": "// Supabase GET returns an array. Empty array = no duplicate.\nconst data = $input.first().json;\n// The HTTP node may return the array directly or wrap it.\n// Handle both: if data is an array, check length. If data has a length property (array-like), check it.\nconst arr = Array.isArray(data) ? data : (data.data ? data.data : [data]);\nconst isEmpty = Array.isArray($input.first().json) ? $input.first().json.length === 0 : !$input.first().json.id;\n\n// Actually, n8n HTTP node with array response: each array element becomes a separate item.\n// So if Supabase returns [], n8n passes 0 items. If it returns [{id:1}], n8n passes 1 item.\n// But with a single GET, the response body is the array itself.\n// Let's just check: did we get an item with an id field?\nconst hasDuplicate = !!$input.first().json.id;\n\nreturn [{ json: { ...$('Filter Leads').first().json, _hasDuplicate: hasDuplicate } }];"
      },
