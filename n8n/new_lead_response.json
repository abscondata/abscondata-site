      "id": "trigger-gmail",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [0, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "FILL_IN",
          "name": "Gmail — Test Client"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Filter out newsletters, no-reply, notifications, and thread replies.\n// Keep only candidate lead emails from unknown senders.\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const headers = item.json.payload?.headers ?? [];\n  const from = (headers.find(h => h.name?.toLowerCase() === 'from')?.value ?? item.json.from ?? '').toLowerCase();\n  const subject = headers.find(h => h.name?.toLowerCase() === 'subject')?.value ?? item.json.subject ?? '';\n  const inReplyTo = headers.find(h => h.name?.toLowerCase() === 'in-reply-to')?.value ?? '';\n  const references = headers.find(h => h.name?.toLowerCase() === 'references')?.value ?? '';\n\n  // Exclude patterns\n  const excludeSenders = [\n    'noreply', 'no-reply', 'donotreply', 'do-not-reply',\n    'notifications@', 'notification@', 'alerts@', 'alert@',\n    'newsletter@', 'news@', 'marketing@', 'promo@',\n    'updates@', 'info@mailchimp', 'bounce@',\n    'mailer-daemon', 'postmaster@',\n    'support@google', 'calendar-notification'\n  ];\n\n  const isExcluded = excludeSenders.some(pattern => from.includes(pattern));\n  const isReply = !!(inReplyTo || references);\n  const hasBody = !!(item.json.snippet || item.json.text || item.json.textPlain || item.json.textHtml);\n\n  if (!isExcluded && !isReply && hasBody && from.length > 0) {\n    // Extract clean fields\n    const senderMatch = from.match(/^(.+?)\\s*<(.+?)>$/);\n    const senderName = senderMatch ? senderMatch[1].replace(/\"/g, '').trim() : '';\n    const senderEmail = senderMatch ? senderMatch[2].trim() : from.trim();\n    const body = item.json.text || item.json.textPlain || item.json.snippet || '';\n    const messageId = item.json.id || item.json.messageId || '';\n    const receivedAt = item.json.internalDate\n      ? new Date(parseInt(item.json.internalDate)).toISOString()\n      : new Date().toISOString();\n\n    results.push({\n      json: {\n        ...item.json,\n        _parsed: {\n          senderName,\n          senderEmail,\n          subject,\n          body,\n          bodyExcerpt: body.substring(0, 500),\n          messageId,\n          receivedAt\n        }\n      }\n    });\n  }\n}\n\nif (results.length === 0) {\n  // Nothing to process — end workflow silently\n  return [];\n}\n\nreturn results;"
      },
      "id": "filter-emails",
      "name": "Filter Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 300]
