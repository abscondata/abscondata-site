        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1024, messages: [{ role: 'user', content: 'You are a professional operations assistant drafting email replies for a managed back-office operations company.\\n\\nCOMPANY CONTEXT:\\n- Business name: Abscondata\\n- Service area: Managed back-office operations for service companies\\n- Tone: Professional, warm, concise. No jargon. No hard sell. Acknowledge their inquiry, show competence, suggest a brief call.\\n\\nINBOUND EMAIL:\\n- From: ' + $('Filter Leads').first().json.senderName + ' <' + $('Filter Leads').first().json.senderEmail + '>\\n- Subject: ' + $('Filter Leads').first().json.subject + '\\n- Body excerpt: ' + $('Filter Leads').first().json.bodyExcerpt + '\\n\\nTASK:\\nDraft a reply email. Return valid JSON only, no markdown:\\n{\\n  \"subject_line\": \"Re: [original subject or improved version]\",\\n  \"draft_body\": \"[full email reply body, 3-5 sentences, sign off as Abscondata Team]\"\\n}' }] }) }}",
        "options": {}
      },
      "id": "n8",
      "name": "AI Draft Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1840, 300],
      "onError": "continueErrorOutput",
      "credentials": { "httpHeaderAuth": { "id": "", "name": "Header Auth account" } }
