        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\n        \"You are a professional operations assistant drafting email replies for a managed back-office operations company.\\n\\n\"\n        + \"COMPANY CONTEXT:\\n\"\n        + \"- Business name: Abscondata\\n\"\n        + \"- Service area: Managed back-office operations for service companies\\n\"\n        + \"- Tone: Professional, warm, concise. No jargon. No hard sell. Acknowledge their inquiry, show competence, suggest a brief call.\\n\\n\"\n        + \"INBOUND EMAIL:\\n\"\n        + \"- From: \" + $('Filter Leads').first().json.senderName + \" <\" + $('Filter Leads').first().json.senderEmail + \">\\n\"\n        + \"- Subject: \" + $('Filter Leads').first().json.subject + \"\\n\"\n        + \"- Body excerpt: \" + $('Filter Leads').first().json.bodyExcerpt + \"\\n\\n\"\n        + \"TASK:\\nDraft a reply email. Return valid JSON only, no markdown:\\n{\\n  \\\"subject_line\\\": \\\"Re: [original subject or improved version]\\\",\\n  \\\"draft_body\\\": \\\"[full email reply body, 3-5 sentences, sign off as Abscondata Team]\\\"\\n}\"\n      ) }}\n    }\n  ]\n}",
        "options": {}
